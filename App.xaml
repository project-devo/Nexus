<Application x:Class="Nexus.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <Color x:Key="BackgroundColor">#0D1117</Color>
        <Color x:Key="PanelColor">#161B22</Color>
        <Color x:Key="CardColor">#21262D</Color>
        <Color x:Key="BorderColor">#30363D</Color>
        <Color x:Key="PrimaryTextColor">#F0F6FC</Color>
        <Color x:Key="SecondaryTextColor">#8B949E</Color>
        <Color x:Key="AccentColor">#58A6FF</Color>
        
        <SolidColorBrush x:Key="BackgroundBrush" Color="#0D1117"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#161B22"/>
        <SolidColorBrush x:Key="CardBrush" Color="#21262D"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#30363D"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F0F6FC"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#8B949E"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#58A6FF"/>
    </Application.Resources>
</Application>
